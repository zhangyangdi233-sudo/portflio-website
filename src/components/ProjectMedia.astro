---
import type { ProjectMedia as Media } from "../lib/types";

interface Props {
  media: Media;
  eager?: boolean;
  preview?: boolean;
}

const { media, eager = false, preview = false } = Astro.props;
---

<figure class="project-media" data-reveal={preview ? undefined : ""}>
  {
    media.type === "image" ? (
      <img src={media.src} alt={media.alt} loading={eager ? "eager" : "lazy"} decoding="async" />
    ) : (
      <video src={media.src} muted playsinline controls={!preview} preload="metadata" aria-label={media.alt} />
    )
  }
  {!preview && media.caption && <figcaption>{media.caption}</figcaption>}
</figure>
