---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { buildHomeComposition } from "../../lib/home-composition";
import { assertLanguage, languageLabels, languages, ui } from "../../lib/i18n";
import { getLocalizedProject, sortProjects } from "../../lib/projects";
import { getLocalizedProfile, siteProfile } from "../../lib/site-data";
import type { Project } from "../../lib/types";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = assertLanguage(Astro.params.lang);
const labels = ui[lang];
const profile = getLocalizedProfile(lang);
const projectEntries = await getCollection("projects");
const projects = sortProjects(projectEntries.map((entry) => entry.data as Project));
const compositionRows = buildHomeComposition(projects);
const title = `${siteProfile.artistName} | ${profile.role}`;
const projectCount = String(projects.length).padStart(2, "0");
const featuredProjects = compositionRows.slice(0, Math.min(6, compositionRows.length));
const popupProjects = ["x-wheel", "emida", "wake-up"]
  .map((slug) => projects.find((project) => project.slug === slug))
  .filter((project): project is Project => Boolean(project));

const scatterPositions = [
  ["-30vw", "20vh", -15],
  ["4vw", "12vh", 7],
  ["34vw", "27vh", -9],
  ["58vw", "6vh", 13],
  ["86vw", "25vh", -18],
  ["110vw", "13vh", 9],
  ["138vw", "31vh", -6],
  ["164vw", "8vh", 18],
  ["190vw", "23vh", -12],
  ["216vw", "14vh", 10],
  ["244vw", "30vh", -16],
  ["270vw", "7vh", 15],
  ["300vw", "24vh", -8],
  ["328vw", "15vh", 11]
] as const;

const mediaPool = featuredProjects
  .flatMap((project, projectIndex) => {
    const localized = getLocalizedProject(project, lang);
    const mediaItems = project.slug === "wake-up" ? project.media.slice(0, 4) : project.media.slice(0, 2);

    return mediaItems.map((media, mediaIndex) => ({
      project,
      projectIndex,
      media,
      mediaIndex,
      localized
    }));
  })
  .slice(0, scatterPositions.length);
---

<BaseLayout lang={lang} title={title} description={profile.statement[0]} pageClass="home-page composition-home">
  <nav class="cinema-nav" aria-label="Homepage navigation" data-cinema-nav>
    <a href={`/${lang}/works/`}>PORTFOLIO</a>
    <a href={`/${lang}/about/`}>CIBA</a>
  </nav>

  <div class="cinema-language" aria-label="Language switcher">
    {
      languages.map((targetLang) => (
        <a class:list={{ "is-active": targetLang === lang }} href={`/${targetLang}/`}>
          {languageLabels[targetLang]}
        </a>
      ))
    }
  </div>

  <section class="cinema-scroll" data-cinema-scroll>
    <div class="cinema-stage">
      <div class="cinema-copy-grid">
        <div class="cinema-title-stack" aria-live="polite">
          {
            featuredProjects.map((project, index) => {
              const localized = getLocalizedProject(project, lang);
              const words = localized.title.toUpperCase().split(" ");

              return (
                <h1
                  class:list={["cinema-title", { "is-active": index === 0 }]}
                  aria-label={localized.title}
                  data-cinema-title
                  data-work-index={index}
                >
                  {words.map((word) => (
                    <span class="cinema-word">
                      {Array.from(word).map((letter) => (
                        <span class="cinema-letter-mask">
                          <span class="cinema-letter-roll">
                            <span>{letter}</span>
                            <span aria-hidden="true">{letter}</span>
                          </span>
                        </span>
                      ))}
                    </span>
                  ))}
                </h1>
              );
            })
          }
        </div>

        <div class="cinema-description-stack">
          {
            featuredProjects.map((project, index) => {
              const localized = getLocalizedProject(project, lang);

              return (
                <p class:list={["cinema-description", { "is-active": index === 0 }]} data-cinema-description data-work-index={index}>
                  {localized.summary}
                </p>
              );
            })
          }
        </div>

        <p class="cinema-side-note">
          Selected works are treated as files returning to the surface: extracted, misplaced, and made visible through scroll.
        </p>
      </div>

      <div class="cinema-media-field" aria-label="Scrollable featured works">
        {
          mediaPool.map((item, index) => {
            const [x, y, rotation] = scatterPositions[index];

            return (
              <a
                class="cinema-media"
                href={`/${lang}/works/${item.project.slug}/`}
                data-cinema-media
                data-work-index={item.projectIndex}
                style={`--scatter-x:${x};--scatter-y:${y};--scatter-r:${rotation}deg;--media-order:${index};`}
              >
                <img
                  src={item.media.src}
                  alt={item.media.alt}
                  loading={item.projectIndex === 0 && item.mediaIndex === 0 ? "eager" : "lazy"}
                  decoding="async"
                />
                <span>{String(item.projectIndex + 1).padStart(2, "0")} / {item.localized.title}</span>
              </a>
            );
          })
        }
      </div>
    </div>
  </section>

  <section class="cinema-statement" data-reveal>
    <p>{profile.statement[1]}</p>
  </section>

  <section class="floating-window-layer" aria-label="Highlighted project windows">
    {
      popupProjects.map((project, index) => {
        const localized = getLocalizedProject(project, lang);

        return (
          <article class="work-window" data-work-window style={`--window-index:${index};`}>
            <div class="work-window__bar" data-window-handle>
              <span>{localized.title}</span>
              <button type="button" aria-label={`Close ${localized.title}`} data-window-close>CLOSE</button>
            </div>
            <figure>
              <a href={`/${lang}/works/${project.slug}/`}>
                <img src={project.media[0].src} alt={project.media[0].alt} loading="lazy" decoding="async" />
              </a>
            </figure>
            <div class="work-window__actions">
              <a href={`/${lang}/works/${project.slug}/`}>OPEN</a>
              <button type="button" data-window-close>NO</button>
            </div>
          </article>
        );
      })
    }
  </section>

  <section class="file-extract" aria-labelledby="file-extract-title" data-file-extract>
    <div class="file-extract__sticky">
      <div class="file-extract__copy" data-reveal>
        <p class="file-extract__meta">02 / {projectCount} {labels.works}</p>
        <h2 id="file-extract-title">EXTRACTED WORKS</h2>
        <p>
          A restrained index of files, studies, games, and image systems. Scroll to pull each work out of the archive,
          then open the project page for the full record.
        </p>
      </div>

      <div class="file-stack" aria-label="Project file stack">
        {
          featuredProjects.map((project, index) => {
            const localized = getLocalizedProject(project, lang);

            return (
              <a
                class="file-card"
                href={`/${lang}/works/${project.slug}/`}
                data-file-card
                style={`--file-index:${index};--project-color:${project.palette.primary};`}
              >
                <div class="file-card__header">
                  <span>{String(index + 1).padStart(2, "0")}</span>
                  <strong>{localized.title}</strong>
                </div>
                <p>{localized.summary}</p>
                <figure>
                  <img src={project.media[0].src} alt={project.media[0].alt} loading="lazy" decoding="async" />
                </figure>
              </a>
            );
          })
        }
      </div>
    </div>
  </section>

  <section class="minimal-index" aria-labelledby="minimal-index-title">
    <p class="file-extract__meta">{labels.index}</p>
    <h2 id="minimal-index-title">PORTFOLIO / CIBA</h2>
    <div class="minimal-index__list">
      {
        compositionRows.map((project, index) => {
          const localized = getLocalizedProject(project, lang);

          return (
            <a href={`/${lang}/works/${project.slug}/`} data-reveal>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <strong>{localized.title}</strong>
              <span>{project.year}</span>
            </a>
          );
        })
      }
    </div>
  </section>
</BaseLayout>
