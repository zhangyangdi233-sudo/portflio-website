---
import { DEFAULT_LANG, languages } from "../lib/i18n";
---

<!doctype html>
<html lang={DEFAULT_LANG}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>糍粑</title>
    <meta name="robots" content="noindex" />
    <script is:inline define:vars={{ languages, fallback: DEFAULT_LANG }}>
      const supported = languages;
      const preferred = (navigator.languages || [navigator.language || fallback])
        .map((language) => language.toLowerCase().split("-")[0])
        .find((language) => supported.includes(language));
      window.location.replace(`/${preferred || fallback}/`);
    </script>
  </head>
  <body>
    <main>
      <a href={`/${DEFAULT_LANG}/`}>Enter portfolio</a>
    </main>
  </body>
</html>
